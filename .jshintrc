{
  "esversion": 11,
  "browser": true,
  "devel": true,
  "node": false,
  "strict": false,
  "undef": true,
  "unused": false,
  "curly": false,
  "eqeqeq": false,
  "freeze": true,
  "futurehostile": true,
  "latedef": false,
  "loopfunc": true,
  "noarg": true,
  "nonew": true,
  "shadow": "outer",
  "-W014": true,
  "-W054": true,
  "-W120": true,
  "-W138": true,
  "globals": {
    "WebSocket": true,
    "TextEncoder": true,
    "TextDecoder": true,
    "TextDecoderStream": true,
    "Bluetooth": true,
    "BluetoothDevice": true,
    "BluetoothRemoteGATTServer": true,
    "BluetoothRemoteGATTService": true,
    "BluetoothRemoteGATTCharacteristic": true,
    "DataView": true,
    "Float32Array": true,
    "Uint8Array": true,
    "URL": true,
    "Blob": true,
    "Event": true,
    "CustomEvent": true,
    "EventTarget": true,
    "DOMException": true,
    "AudioContext": true,
    "webkitAudioContext": true,
    "navigator": true,
    "performance": true,
    "showSaveFilePicker": true,
    "FileSystemFileHandle": true,
    "FileSystemWritableFileStream": true,
    "structuredClone": true
  }
}
