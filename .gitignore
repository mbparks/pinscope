build/
*.elf
*.bin
*.hex
*.eep
*.map

# CI workflow staging dirs (compile-sketches copies each .ino into here)
sketches/

# Saved data from PinScope itself
captures/
*.csv
pinscope_capture_*.json
pinscope_session_*.json

# Local secrets file pattern for the MQTT firmware
arduino_secrets.h
